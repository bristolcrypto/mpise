diff --git a/riscv/insns/sraiadd.h b/riscv/insns/sraiadd.h
new file mode 100644
index 00000000..a2ed1c98
--- /dev/null
+++ b/riscv/insns/sraiadd.h
@@ -0,0 +1,12 @@
+if     ( xlen == 32 ) {
+  abort();
+}
+else if( xlen == 64 ) {
+   int64_t x   = READ_REG( insn.rs1() );
+   int64_t y   = READ_REG( insn.rs2() );
+  uint64_t imm = insn.funct7() & 0x3F;
+
+   int64_t r   = x + ( y >> imm );
+
+  WRITE_REG( insn.rd(), r );
+}
