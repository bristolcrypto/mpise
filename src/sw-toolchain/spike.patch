diff --git a/riscv/insns/cacc.h b/riscv/insns/cacc.h
new file mode 100644
index 00000000..6fa325a4
--- /dev/null
+++ b/riscv/insns/cacc.h
@@ -0,0 +1,22 @@
+if( ( xlen == 32 ) || ( xlen == 64 ) ) {
+  int w = xlen;
+
+  #if   defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 0 )
+  // !destructive
+  uint128_t x = READ_REG( insn.rs1() );
+  uint128_t y = READ_REG( insn.rs2() );
+  uint128_t z = READ_REG( insn.rs3() );
+  #elif defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 1 )
+  //  destructive
+  uint128_t x = READ_REG( insn.rs1() );
+  uint128_t y = READ_REG( insn.rs2() );
+  uint128_t z = READ_REG( insn.rd()  );
+  #endif
+
+  uint128_t r = ( ( x + y ) >> w ) + z;
+
+  WRITE_REG( insn.rd(), r );
+}
+else {
+  abort();
+}
diff --git a/riscv/insns/macchu.h b/riscv/insns/macchu.h
new file mode 100644
index 00000000..d02fa05e
--- /dev/null
+++ b/riscv/insns/macchu.h
@@ -0,0 +1,49 @@
+if( ( xlen == 32 ) || ( xlen == 64 ) ) {
+  int w = xlen;
+
+  #if   defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 0 )
+  // !destructive
+  uint128_t x   = READ_REG( insn.rs1() );
+  uint128_t y   = READ_REG( insn.rs2() );
+  uint128_t z   = READ_REG( insn.rs3() );
+  #elif defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 1 )
+  //  destructive
+  uint128_t x   = READ_REG( insn.rs1() );
+  uint128_t y   = READ_REG( insn.rs2() );
+  uint128_t z   = READ_REG( insn.rd()  );
+  #endif
+
+  #if   defined( MPISE_STATELESS   ) && ( MPISE_STATELESS   == 0 )
+  // !stateless
+  int c = p->get_csr( 0x800, insn, false ) & 0xF;
+  #elif defined( MPISE_STATELESS   ) && ( MPISE_STATELESS   == 1 )
+  //  stateless
+  int c = ( ( insn.funct2() & 0x3 ) << 2 ) |
+          ( ( insn.funct3() & 0x6 ) >> 1 ) ;
+  #endif
+
+  int f_3, f_4, f_5;
+
+  if     ( c == 0xF ) { //    full-radix
+    f_3 =        1;
+    f_4 =  w      ;
+    f_5 =  w      ;
+  }
+  else if( c != 0xF ) { // reduced-radix
+    f_3 =        0;
+    f_4 =  w      ;
+    f_5 = (w-15)+c;
+  }
+
+  uint128_t t_0 = x * y;
+  uint128_t t_1 = f_3 ? z : 0;
+  uint128_t t_2 = f_3 ? 0 : z;
+
+  uint128_t m   = ( ( uint128_t )( 1 ) << f_4 ) - 1;
+  uint128_t r   = ( ( ( t_0 + t_1 ) >> f_5 ) & m ) + t_2;
+
+  WRITE_REG( insn.rd(), r );
+}
+else {
+  abort();
+}
