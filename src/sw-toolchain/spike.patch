diff --git a/riscv/insns/cacc.h b/riscv/insns/cacc.h
new file mode 100644
index 00000000..a4923a17
--- /dev/null
+++ b/riscv/insns/cacc.h
@@ -0,0 +1,20 @@
+if     ( xlen == 32 ) {
+  abort();
+}
+else if( xlen == 64 ) {
+  #if   defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 0 )
+  // !destructive
+  uint64_t x = READ_REG( insn.rs1() );
+  uint64_t y = READ_REG( insn.rs2() );
+  uint64_t z = READ_REG( insn.rs3() );
+  #elif defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 1 )
+  //  destructive
+  uint64_t x = READ_REG( insn.rs1() );
+  uint64_t y = READ_REG( insn.rs2() );
+  uint64_t z = READ_REG( insn.rd()  );
+  #endif
+
+  uint64_t r = ( ( ( uint128_t )( x ) + ( uint128_t )( y ) ) >> xlen ) + ( uint128_t )( z );
+
+  WRITE_REG( insn.rd(), r );
+}
diff --git a/riscv/insns/macchu.h b/riscv/insns/macchu.h
new file mode 100644
index 00000000..bc38fbe8
--- /dev/null
+++ b/riscv/insns/macchu.h
@@ -0,0 +1,47 @@
+if     ( xlen == 32 ) {
+  abort();
+}
+else if( xlen == 64 ) {
+  #if   defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 0 )
+  // !destructive
+  uint64_t x   = READ_REG( insn.rs1() );
+  uint64_t y   = READ_REG( insn.rs2() );
+  uint64_t z   = READ_REG( insn.rs3() );
+  #elif defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 1 )
+  //  destructive
+  uint64_t x   = READ_REG( insn.rs1() );
+  uint64_t y   = READ_REG( insn.rs2() );
+  uint64_t z   = READ_REG( insn.rd()  );
+  #endif
+
+  #if   defined( MPISE_STATELESS   ) && ( MPISE_STATELESS   == 0 )
+  // !stateless
+  uint64_t c   = p->get_csr( 0x800, insn, false ) & 0xF;
+  #elif defined( MPISE_STATELESS   ) && ( MPISE_STATELESS   == 1 )
+  //  stateless
+  uint64_t c   = ( ( insn.funct2() & 0x3 ) << 2 ) |
+                 ( ( insn.funct3() & 0x6 ) >> 1 ) ;
+  #endif
+
+  int f_3, f_4, f_5;
+
+  if     ( c == 0xF ) { //    full-radix
+    f_3 =      1;
+    f_4 =     64; // or xlen
+    f_5 =     64; // or xlen
+  }
+  else if( c != 0xF ) { // reduced-radix
+    f_3 =      0;
+    f_4 =     64; // or xlen
+    f_5 = c + 49;
+  }
+
+  uint64_t t_0 = x * y;
+  uint64_t t_1 = f_3 ? z : 0;
+  uint64_t t_2 = f_3 ? 0 : z;
+
+  uint64_t m   = ( 1 << f_4 ) - 1;
+  uint64_t r   = ( ( ( t_0 + t_1 ) >> f_5 ) & m ) + t_2;
+
+  WRITE_REG( insn.rd(), r );
+}
