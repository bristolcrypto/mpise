diff --git a/riscv/insns/cacc.h b/riscv/insns/cacc.h
new file mode 100644
index 00000000..d6c7cca8
--- /dev/null
+++ b/riscv/insns/cacc.h
@@ -0,0 +1,23 @@
+int w = xlen;
+
+if     ( xlen == 32 ) {
+  #if   defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 0 )
+  // !destructive
+  WRITE_REG( insn.rd(), sext_xlen( __cacc< uint64_t>( w, READ_REG( insn.rs1() ), READ_REG( insn.rs2() ), READ_REG( insn.rs3() ) ) ) );
+  #elif defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 1 )
+  //  destructive
+  WRITE_REG( insn.rd(), sext_xlen( __cacc< uint64_t>( w, READ_REG( insn.rs1() ), READ_REG( insn.rs2() ), READ_REG( insn.rd()  ) ) ) );
+  #endif
+}
+else if( xlen == 64 ) {
+  #if   defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 0 )
+  // !destructive
+  WRITE_REG( insn.rd(), sext_xlen( __cacc<uint128_t>( w, READ_REG( insn.rs1() ), READ_REG( insn.rs2() ), READ_REG( insn.rs3() ) ) ) );
+  #elif defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 1 )
+  //  destructive
+  WRITE_REG( insn.rd(), sext_xlen( __cacc<uint128_t>( w, READ_REG( insn.rs1() ), READ_REG( insn.rs2() ), READ_REG( insn.rd()  ) ) ) );
+  #endif
+}
+else {
+  abort();
+}
