+  WRITE_REG( insn.rd(), sext_xlen( __macchu< uint64_t>( w, READ_REG( insn.rs1() ), READ_REG( insn.rs2() ), READ_REG( insn.rs3() ), c ) ) );
+  #elif defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 1 )
+  //  destructive
+  WRITE_REG( insn.rd(), sext_xlen( __macchu< uint64_t>( w, READ_REG( insn.rs1() ), READ_REG( insn.rs2() ), READ_REG( insn.rd()  ), c ) ) );
+  #endif
+}
+else if( xlen == 64 ) {
+  #if   defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 0 )
+  // !destructive
+  WRITE_REG( insn.rd(), sext_xlen( __macchu<uint128_t>( w, READ_REG( insn.rs1() ), READ_REG( insn.rs2() ), READ_REG( insn.rs3() ), c ) ) );
+  #elif defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 1 )
+  //  destructive
+  WRITE_REG( insn.rd(), sext_xlen( __macchu<uint128_t>( w, READ_REG( insn.rs1() ), READ_REG( insn.rs2() ), READ_REG( insn.rd()  ), c ) ) );
+  #endif
+}
+else {
+  abort();
+}
