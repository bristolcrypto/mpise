diff --git a/riscv/insns/maccrrhu.h b/riscv/insns/maccrrhu.h
new file mode 100644
index 00000000..2536942b
--- /dev/null
+++ b/riscv/insns/maccrrhu.h
@@ -0,0 +1,36 @@
+if     ( xlen == 32 ) {
+  abort();
+}
+else if( xlen == 64 ) {
+  #if   defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 0 )
+  // !destructive
+  uint64_t x   = READ_REG( insn.rs1() );
+  uint64_t y   = READ_REG( insn.rs2() );
+  uint64_t z   = READ_REG( insn.rs3() );
+  #elif defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 1 )
+  //  destructive
+  uint64_t x   = READ_REG( insn.rs1() );
+  uint64_t y   = READ_REG( insn.rs2() );
+  uint64_t z   = READ_REG( insn.rd()  );
+  #endif
+
+  #if   defined( MPISE_STATELESS   ) && ( MPISE_STATELESS   == 0 )
+  // !stateless
+  uint64_t imm = p->get_csr( 0x800, insn, false );
+
+  uint64_t f_2 =     xlen;
+  uint64_t f_3 = imm + 48;
+  #elif defined( MPISE_STATELESS   ) && ( MPISE_STATELESS   == 1 )
+  //  stateless
+  uint64_t imm = ( ( insn.funct2() & 0x3 ) << 2 ) |
+                 ( ( insn.funct3() & 0x6 ) >> 1 ) ;
+
+  uint64_t f_2 =     xlen;
+  uint64_t f_3 = imm + 48;
+  #endif
+
+  uint64_t m = ( ( uint128_t )( 1 ) << f_2 ) - 1;
+  uint64_t r = ( ( ( ( uint128_t )( x ) * ( uint128_t )( y ) ) >> f_3 ) & m ) + ( uint128_t )( z );
+
+  WRITE_REG( insn.rd(), r );
+}
