diff --git a/riscv/insns/cacc.h b/riscv/insns/cacc.h
new file mode 100644
index 00000000..a4923a17
--- /dev/null
+++ b/riscv/insns/cacc.h
@@ -0,0 +1,20 @@
+if     ( xlen == 32 ) {
+  abort();
+}
+else if( xlen == 64 ) {
+  #if   defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 0 )
+  // !destructive
+  uint64_t x = READ_REG( insn.rs1() );
+  uint64_t y = READ_REG( insn.rs2() );
+  uint64_t z = READ_REG( insn.rs3() );
+  #elif defined( MPISE_DESTRUCTIVE ) && ( MPISE_DESTRUCTIVE == 1 )
+  //  destructive
+  uint64_t x = READ_REG( insn.rs1() );
+  uint64_t y = READ_REG( insn.rs2() );
+  uint64_t z = READ_REG( insn.rd()  );
+  #endif
+
+  uint64_t r = ( ( ( uint128_t )( x ) + ( uint128_t )( y ) ) >> xlen ) + ( uint128_t )( z );
+
+  WRITE_REG( insn.rd(), r );
+}
