+  uint128_t r   = ( ( ( t_0 + t_1 ) >> f_2 ) & m ) + t_2;
+
+  WRITE_REG( insn.rd(), r );
+}
+else {
+  abort();
+}
diff --git a/riscv/insns/sraiadd.h b/riscv/insns/sraiadd.h
new file mode 100644
index 00000000..510c93a4
--- /dev/null
+++ b/riscv/insns/sraiadd.h
@@ -0,0 +1,14 @@
+if( ( xlen == 32 ) || ( xlen == 64 ) ) {
+  int w = xlen;
+
+   int64_t x   = READ_REG( insn.rs1() );
+   int64_t y   = READ_REG( insn.rs2() );
+  uint64_t imm = insn.funct7() & 0x3F;
+
+   int64_t r   = x + ( y >> imm );
+
+  WRITE_REG( insn.rd(), r );
+}
+else {
+  abort();
+}
