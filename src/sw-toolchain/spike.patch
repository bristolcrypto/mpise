@@ -0,0 +1 @@
+#include "arith.h"
diff --git a/riscv/arith.h b/riscv/arith.h
index c60fcbea..b274c309 100644
--- a/riscv/arith.h
+++ b/riscv/arith.h
@@ -242,4 +242,86 @@ static inline T rotate_left(T x, std::size_t shiftamt) {
   return (x << lshift) | (x >> rshift);
 }
 
+template <typename T>
+static inline T __sraiadd( int w, T x, T y, int imm ) {
+  T r = x + ( y >> imm );
+
+  return r;
+}
+
+template <typename T>
+static inline T __cacc( int w, T x, T y, T z ) {
+  x = x & ( ( ( T )( 1 ) << w ) - 1 );
+  y = y & ( ( ( T )( 1 ) << w ) - 1 );
+  z = z & ( ( ( T )( 1 ) << w ) - 1 );
+
+  T r = ( ( x + y ) >> w ) + z;
+
+  r = r & ( ( ( T )( 1 ) << w ) - 1 );
+
+  return r;
+}
+
+template <typename T>
+static inline T __macclu( int w, T x, T y, T z, int c ) {
+  int f_0, f_1, f_2;
+  
+  if     ( c == 0xF ) { //    full-radix
+    f_0 =        1;
+    f_1 =  w      ;
+    f_2 =        0;
+  }
+  else if( c != 0xF ) { // reduced-radix
+    f_0 =        0;
+    f_1 = (w-15)+c;
+    f_2 =        0;
+  }
+
+  x = x & ( ( ( T )( 1 ) << w ) - 1 );
+  y = y & ( ( ( T )( 1 ) << w ) - 1 );
+  z = z & ( ( ( T )( 1 ) << w ) - 1 );
+
+  T t_0 = x * y;
+  T t_1 = f_0 ? z : 0;
+  T t_2 = f_0 ? 0 : z;
+
+  T m   = ( ( T )( 1 ) << f_1 ) - 1;
+  T r   = ( ( ( t_0 + t_1 ) >> f_2 ) & m ) + t_2;
+
+  r = r & ( ( ( T )( 1 ) << w ) - 1 );
+
+  return r;
+}
+
+template <typename T>
+static inline T __macchu( int w, T x, T y, T z, int c ) {
+  int f_3, f_4, f_5;
+  
+  if     ( c == 0xF ) { //    full-radix
+    f_3 =        1;
+    f_4 =  w      ;
+    f_5 =  w      ;
+  }
+  else if( c != 0xF ) { // reduced-radix
+    f_3 =        0;
+    f_4 =  w      ;
+    f_5 = (w-15)+c;
+  }
+
+  x = x & ( ( ( T )( 1 ) << w ) - 1 );
+  y = y & ( ( ( T )( 1 ) << w ) - 1 );
+  z = z & ( ( ( T )( 1 ) << w ) - 1 );
+
+  T t_0 = x * y;
+  T t_1 = f_3 ? z : 0;
+  T t_2 = f_3 ? 0 : z;
+
+  T m   = ( ( T )( 1 ) << f_4 ) - 1;
+  T r   = ( ( ( t_0 + t_1 ) >> f_5 ) & m ) + t_2;
+
+  r = r & ( ( ( T )( 1 ) << w ) - 1 );
+
+  return r;
+}
+
 #endif
