ifndef REPO_HOME
  $(error "execute 'source ./bin/conf.sh' to configure environment")
endif
ifndef REPO_VERSION
  $(error "execute 'source ./bin/conf.sh' to configure environment")
endif

ifndef RISCV
  $(error "set RISCV environment variable to point at toolchain installation")
endif

# =============================================================================

ifeq "${ARCH}" "rv32"
include ${REPO_HOME}/src/sw/share/arch/rv32/Makefile.in
export XLEN=32
export GCC_FLAGS += -DMPISE_XLEN="${XLEN}"
endif
ifeq "${ARCH}" "rv64"
include ${REPO_HOME}/src/sw/share/arch/rv64/Makefile.in
export XLEN=64
export GCC_FLAGS += -DMPISE_XLEN="${XLEN}"
endif

ifeq "${TYPE}" "isa"
export TYPE_ISA      = 1
export GCC_FLAGS += -DMPISE_ISA
endif
ifeq "${TYPE}" "ise"
export TYPE_ISE      = 1
export GCC_FLAGS += -DMPISE_ISE
endif

ifeq "${RADIX}" "${XLEN}"
export RADIX_FULL    = 1
export RADIX_IMM     = $(shell printf '0x%X' $$(( ${RADIX} - ${XLEN} + 15 )))
export GCC_FLAGS +=  -DMPISE_RADIX="${RADIX}" -DMPISE_RADIX_FULL    -DMPISE_RADIX_IMM="${RADIX_IMM}"
else
export RADIX_REDUCED = 1
export RADIX_IMM     = $(shell printf '0x%X' $$(( ${RADIX} - ${XLEN} + 15 )))
export GCC_FLAGS +=  -DMPISE_RADIX="${RADIX}" -DMPISE_RADIX_REDUCED -DMPISE_RADIX_IMM="${RADIX_IMM}"
endif

export GCC_FLAGS += -DMPISE_DESTRUCTIVE="${MPISE_DESTRUCTIVE}" -DMPISE_STATELESS="${MPISE_STATELESS}"

# -----------------------------------------------------------------------------

export INCLUDES   +=            ${REPO_HOME}/src/sw/share/
export INCLUDES   +=            ${REPO_HOME}/src/sw/share/arch/${ARCH}

export  HEADERS   += $(wildcard ${REPO_HOME}/src/sw/share/*.h)
export  HEADERS   += $(wildcard ${REPO_HOME}/src/sw/share/arch/${ARCH}/*.h)

export  SOURCES   += $(wildcard ${REPO_HOME}/src/sw/share/*.c)
export  SOURCES   += $(wildcard ${REPO_HOME}/src/sw/share/arch/${ARCH}/*.c)

export  TARGETS   += ${REPO_HOME}/build/${ALG}
export  TARGETS   += ${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.elf
export  TARGETS   += ${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.bin
export  TARGETS   += ${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.asm

# -----------------------------------------------------------------------------

.SECONDEXPANSION :

${REPO_HOME}/build/${ALG} :
	@mkdir --parents ${@}

${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.elf : $${SOURCES}
	@${RISCV}/bin/${GCC_PREFIX}-gcc ${GCC_FLAGS} ${GCC_PATHS} $(addprefix -I ,${INCLUDES}) -Wall -std='gnu99' -O3 -o ${@} $(filter %.c, ${^}) $(filter %.S, ${^}) ${GCC_LIBS}
${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.bin : ${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.elf
	@${RISCV}/bin/${GCC_PREFIX}-objcopy --output-target='binary' ${<} ${@}
${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.asm : ${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.elf
	@${RISCV}/bin/${GCC_PREFIX}-objdump --disassemble-all ${<} > ${@}

# -----------------------------------------------------------------------------

build :                         ${TARGETS}

clean : 
	@rm --force --recursive ${TARGETS}

# =============================================================================
