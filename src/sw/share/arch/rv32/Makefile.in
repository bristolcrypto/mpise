# =============================================================================

ifeq "${PLATFORM}" "spike"
export GCC_PREFIX  = riscv64-unknown-elf
export GCC_FLAGS  += -march='rv32imafdc_zicsr_zifencei_zicntr' -mabi='ilp32'
export GCC_PATHS  += 
export GCC_LIBS   += 
endif
ifeq "${PLATFORM}" "cva6-verilator"
export GCC_PREFIX  = riscv-none-elf
export GCC_FLAGS  += -march='rv32imafdc_zicsr_zifencei'        -mabi='ilp32'
export GCC_FLAGS  += -DMPISE_STDC_RAND
endif
ifeq "${PLATFORM}" "cva6-fpga"
export GCC_PREFIX  = riscv-none-elf
export GCC_FLAGS  += -march='rv32imafdc_zicsr_zifencei_zicntr' -mabi='ilp32' -static -mcmodel='medany' -fvisibility='hidden' -nostdlib -nostartfiles -g -T ${CVA6}/config/gen_from_riscv_config/linker/link.ld
export GCC_PATHS  += -I ${CVA6}/verif/sim/dv/user_extension -I ${CVA6}/verif/tests/custom/env -I ${CVA6}/verif/tests/custom/common
export GCC_LIBS   += -lgcc

export GCC_FLAGS  += -DMPISE_STDC_RAND
export SOURCES    += ${CVA6}/verif/tests/custom/common/syscalls.c
export SOURCES    += ${CVA6}/verif/tests/custom/common/crt.S
endif

# -----------------------------------------------------------------------------

ifeq "${PLATFORM}" "spike"
run   : build
	@${RISCV}/bin/spike    --isa='rv32imafdc_zicsr_zifencei_zicntr' ${RISCV}/riscv32-unknown-elf/bin/pk ${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.elf

debug : build
	@${RISCV}/bin/spike -d --isa='rv32imafdc_zicsr_zifencei_zicntr' ${RISCV}/riscv32-unknown-elf/bin/pk ${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.elf
endif
ifeq "${PLATFORM}" "cva6-verilator"
run   : build
	@echo "Configure RISCV variable compatible with CVA6 repository before verilator simulation"
	@echo "RISCV is $(RISCV)"
	cd ${CVA6} && \
	bash ${CVA6}/verif/sim/mpise-sim.sh ${ALG}-${ARCH}_${TYPE}

debug : build
	@$(error "can't simulate for PLATFORM=${PLATFORM}")
endif

ifeq "${PLATFORM}" "cva6-fpga"
run   : build
	@$(error "can't simulate for PLATFORM=${PLATFORM}")

debug : build
	@$(error "can't simulate for PLATFORM=${PLATFORM}")
endif

# =============================================================================
