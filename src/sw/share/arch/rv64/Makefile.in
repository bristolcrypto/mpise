ifeq "${SIM}" "spike"
run   : build
	@${RISCV}/bin/spike    --isa='rv64gc_zicsr_zicntr' ${RISCV}/riscv64-unknown-elf/bin/pk ${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.elf

debug : build
	@${RISCV}/bin/spike -d --isa='rv64gc_zicsr_zicntr' ${RISCV}/riscv64-unknown-elf/bin/pk ${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.elf
endif
