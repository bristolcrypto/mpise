# =============================================================================

ifeq "${PLATFORM}" "spike"
export GCC_PREFIX  = riscv64-unknown-elf
export GCC_FLAGS  += -march='rv64imafdc_zicsr_zifencei_zicntr' -mabi='lp64d'
export GCC_FLAGS  +=
export GCC_PATHS  += 
export GCC_LIBS   += 
endif

ifeq "${PLATFORM}" "cva6-verilator"
export GCC_PREFIX  = riscv-none-elf
export GCC_FLAGS  += -march='rv64imafdc_zicsr_zifencei'        -mabi='lp64d'
export GCC_FLAGS  += -DMPISE_STDC_RAND -DTHRESHOLD_DEBUG
endif

ifeq "${PLATFORM}" "cva6-fpga"
export GCC_PREFIX  = riscv-none-elf
export GCC_FLAGS  += -march='rv64imafdc_zicsr_zifencei'        -mabi='lp64d'
export GCC_FLAGS  += -DMPISE_STDC_RAND -DTHRESHOLD_DEBUG
endif

# -----------------------------------------------------------------------------

ifeq "${PLATFORM}" "spike"
run   : build
	@${RISCV}/bin/spike    --isa='rv64imafdc_zicsr_zifencei_zicntr' ${RISCV}/riscv64-unknown-elf/bin/pk ${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.elf

debug : build
	@${RISCV}/bin/spike -d --isa='rv64imafdc_zicsr_zifencei_zicntr' ${RISCV}/riscv64-unknown-elf/bin/pk ${REPO_HOME}/build/${ALG}/${ALG}-${ARCH}_${TYPE}.elf
endif
ifeq "${PLATFORM}" "cva6-verilator"
run   : build
	@echo "Configure RISCV variable compatible with CVA6 repository before verilator simulation"
	@echo "RISCV is $(RISCV)"
	cd ${CVA6} && \
	bash ${CVA6}/verif/sim/mpise-sim.sh ${ALG}-${ARCH}_${TYPE}

debug : build
	@$(error "can't simulate for PLATFORM=${PLATFORM}")
endif

ifeq "${PLATFORM}" "cva6-fpga"
run   : build
	@$(error "can't simulate for PLATFORM=${PLATFORM}")

debug : build
	@$(error "can't simulate for PLATFORM=${PLATFORM}")
endif

# =============================================================================
